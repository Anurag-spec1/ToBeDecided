<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_focused="true">

        <shape>

            <solid android:color="#0D2019"/>

            <corners android:radius="12dp"/>

            <stroke
                android:width="2dp"
                android:color="#4ADE80"/>

        </shape>

    </item>

    <item>

        <shape>

            <solid android:color="#08130F"/>

            <corners android:radius="12dp"/>

            <stroke
                android:width="1dp"
                android:color="#1E5B43"/>

        </shape>

    </item>

</selector>