<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/main_activity_bg"
    tools:context=".activity.DevProfileActivity">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:scrollbars="none">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="34dp">

            <!-- ===================== COVER ===================== -->
            <FrameLayout
                android:id="@+id/coverFrame"
                android:layout_width="0dp"
                android:layout_height="250dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <ImageView
                    android:id="@+id/coverImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@string/cd_cover_photo"
                    android:src="@drawable/panda_cover"
                    android:scaleType="centerCrop" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_cover_overlay" />
            </FrameLayout>

            <!-- ===================== AVATAR (overlaps the cover) ===================== -->
            <FrameLayout
                android:id="@+id/avatarRing"
                android:layout_width="112dp"
                android:layout_height="112dp"
                android:layout_marginTop="-56dp"
                android:background="@drawable/bg_avatar_ring"
                android:elevation="8dp"
                android:padding="4dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/coverFrame">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    app:cardBackgroundColor="#1A2B22"
                    app:cardCornerRadius="52dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/bg_0"
                    app:strokeWidth="4dp">

                    <ImageView
                        android:id="@+id/avatarImage"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="@string/cd_profile_photo"
                        android:scaleType="centerCrop"
                        tools:src="@tools:sample/avatars" />
                </com.google.android.material.card.MaterialCardView>
            </FrameLayout>

            <!-- ===================== NAME + ROLE ===================== -->
            <TextView
                android:id="@+id/nameText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:fontFamily="@font/space_grotesk_semibold"
                android:letterSpacing="-0.01"
                android:text="@string/dev_name"
                android:textColor="@color/text_hi"
                android:textSize="26sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/avatarRing" />

            <TextView
                android:id="@+id/roleText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_role_pill"
                android:fontFamily="@font/jetbrains_mono_medium"
                android:letterSpacing="0.12"
                android:paddingHorizontal="14dp"
                android:paddingVertical="6dp"
                android:text="@string/dev_role"
                android:textAllCaps="true"
                android:textColor="@color/accent"
                android:textSize="12sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/nameText" />

            <!-- ===================== STATS ===================== -->
            <LinearLayout
                android:id="@+id/statsRow"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="26dp"
                android:layout_marginTop="22dp"
                android:orientation="horizontal"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/roleText">

                <!-- Stat card: Experience -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_surface_card"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <FrameLayout
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:layout_marginBottom="10dp"
                        android:background="@drawable/bg_stat_icon">

                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_clock" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/space_grotesk_semibold"
                        android:text="@string/stat_experience_value"
                        android:textColor="@color/text_hi"
                        android:textSize="20sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:fontFamily="@font/inter_medium"
                        android:text="@string/stat_experience_label"
                        android:textColor="@color/text_lo"
                        android:textSize="11.5sp" />
                </LinearLayout>

                <!-- Stat card: Projects delivered -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_surface_card"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <FrameLayout
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:layout_marginBottom="10dp"
                        android:background="@drawable/bg_stat_icon">

                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_box" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/space_grotesk_semibold"
                        android:text="@string/stat_projects_value"
                        android:textColor="@color/text_hi"
                        android:textSize="20sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:fontFamily="@font/inter_medium"
                        android:text="@string/stat_projects_label"
                        android:textColor="@color/text_lo"
                        android:textSize="11.5sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- ===================== ABOUT LABEL ===================== -->
            <TextView
                android:id="@+id/aboutLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="28dp"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/jetbrains_mono_medium"
                android:letterSpacing="0.1"
                android:text="@string/label_about"
                android:textAllCaps="true"
                android:textColor="@color/text_lo"
                android:textSize="11sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/statsRow" />

            <!-- ===================== TERMINAL / BIO CARD ===================== -->
            <LinearLayout
                android:id="@+id/terminalCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="26dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_terminal_card"
                android:orientation="vertical"
                android:padding="18dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/aboutLabel">

                <!-- traffic-light dots -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <View
                        android:layout_width="11dp"
                        android:layout_height="11dp"
                        android:background="@drawable/dot_red" />

                    <View
                        android:layout_width="11dp"
                        android:layout_height="11dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/dot_yellow" />

                    <View
                        android:layout_width="11dp"
                        android:layout_height="11dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/dot_green" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:fontFamily="@font/jetbrains_mono_medium"
                    android:text="@string/terminal_prompt"
                    android:textColor="@color/accent"
                    android:textSize="12.5sp" />

                <TextView
                    android:id="@+id/bioText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/inter_regular"
                    android:lineSpacingMultiplier="1.3"
                    android:text="@string/bio_text"
                    android:textColor="@color/text_mid"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- ===================== CONNECT LABEL ===================== -->
            <TextView
                android:id="@+id/connectLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="28dp"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/jetbrains_mono_medium"
                android:letterSpacing="0.1"
                android:text="@string/label_connect"
                android:textAllCaps="true"
                android:textColor="@color/text_lo"
                android:textSize="11sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/terminalCard" />

            <LinearLayout
                android:id="@+id/linksContainer"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="26dp"
                android:layout_marginTop="10dp"
                android:orientation="vertical"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/connectLabel">

                <include
                    android:id="@+id/tileGithub"
                    layout="@layout/item_link_tile"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <include
                    android:id="@+id/tileLinkedin"
                    layout="@layout/item_link_tile"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp" />

                <include
                    android:id="@+id/tileInstagram"
                    layout="@layout/item_link_tile"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp" />

                <include
                    android:id="@+id/tileGmail"
                    layout="@layout/item_link_tile"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp" />
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>
</FrameLayout>
