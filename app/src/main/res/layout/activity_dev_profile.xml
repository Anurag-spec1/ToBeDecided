<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/void_bg">

    <ImageView
        android:id="@+id/bg_image"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        android:src="@drawable/main_activity_bg" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_vignette" />

    <View
        android:id="@+id/scanline_beam"
        android:layout_width="match_parent"
        android:layout_height="140dp"
        android:layout_gravity="top"
        android:background="@drawable/bg_scanline"
        android:translationY="-140dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:minHeight="match_parent"
            android:padding="20dp">

            <FrameLayout
                android:id="@+id/card_frame"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:alpha="0"
                android:padding="14dp">

                <View
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="top|left"
                    android:background="@drawable/corner_bracket" />

                <View
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="top|right"
                    android:background="@drawable/corner_bracket"
                    android:scaleX="-1" />

                <View
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="bottom|left"
                    android:background="@drawable/corner_bracket"
                    android:scaleY="-1" />

                <View
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="bottom|right"
                    android:background="@drawable/corner_bracket"
                    android:scaleX="-1"
                    android:scaleY="-1" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|left"
                    android:layout_marginStart="26dp"
                    android:layout_marginTop="6dp"
                    android:background="@color/void_bg"
                    android:fontFamily="monospace"
                    android:paddingHorizontal="4dp"
                    android:text="SYS.01"
                    android:textColor="@color/grad_a"
                    android:textSize="9sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|right"
                    android:layout_marginTop="6dp"
                    android:layout_marginEnd="26dp"
                    android:background="@color/void_bg"
                    android:fontFamily="monospace"
                    android:paddingHorizontal="4dp"
                    android:text="ONLINE"
                    android:textColor="@color/grad_a"
                    android:textSize="9sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_panel"
                    android:orientation="vertical"
                    android:paddingStart="26dp"
                    android:paddingTop="36dp"
                    android:paddingEnd="26dp"
                    android:paddingBottom="26dp">

                    <FrameLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginBottom="20dp">

                        <com.hustlers.tobedecided.ui.components.RotatingRingView
                            android:id="@+id/ring"
                            android:layout_width="106dp"
                            android:layout_height="106dp" />

                        <FrameLayout
                            android:layout_width="94dp"
                            android:layout_height="94dp"
                            android:layout_gravity="center"
                            android:background="@drawable/bg_avatar_circle"
                            android:clipChildren="true">

                            <TextView
                                android:id="@+id/avatar_initials"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:fontFamily="sans-serif-condensed"
                                android:text="AM"
                                android:textColor="@color/neon_green"
                                android:textSize="28sp"
                                android:textStyle="bold" />

                            <View
                                android:id="@+id/avatar_scan"
                                android:layout_width="match_parent"
                                android:layout_height="24dp"
                                android:background="@drawable/bg_scanline"
                                android:translationY="-30dp" />
                        </FrameLayout>
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginBottom="6dp"
                        android:fontFamily="monospace"
                        android:text="&gt; whoami"
                        android:textColor="@color/text_faint"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/name_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-condensed"
                        android:gravity="center"
                        android:letterSpacing="0.04"
                        android:minHeight="34dp"
                        android:textColor="@color/neon_green"
                        android:textSize="26sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/role_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="8dp"
                        android:alpha="0"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.03"
                        android:text="FULL STACK DEVELOPER"
                        android:textColor="@color/grad_a"
                        android:textSize="12.5sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="26dp"
                        android:layout_marginBottom="16dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <com.hustlers.tobedecided.ui.components.AnimatedDividerView
                            android:id="@+id/divider_left"
                            android:layout_width="0dp"
                            android:layout_height="2dp"
                            android:layout_weight="1" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginHorizontal="8dp"
                            android:letterSpacing="0.15"
                            android:text="CONNECT"
                            android:textColor="@color/text_lo"
                            android:textSize="11sp" />

                        <com.hustlers.tobedecided.ui.components.AnimatedDividerView
                            android:id="@+id/divider_right"
                            android:layout_width="0dp"
                            android:layout_height="2dp"
                            android:layout_weight="1" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <carbon.widget.LinearLayout
                            android:id="@+id/row_github"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="11dp"
                            android:alpha="0"
                            android:background="@drawable/bg_link_row"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground"
                            android:orientation="horizontal">

                            <View
                                android:layout_width="3dp"
                                android:layout_height="match_parent"
                                android:background="@color/acc_github" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal"
                                android:paddingStart="13dp"
                                android:paddingTop="13dp"
                                android:paddingEnd="16dp"
                                android:paddingBottom="13dp">

                                <FrameLayout
                                    android:layout_width="34dp"
                                    android:layout_height="34dp"
                                    android:background="@drawable/bg_icon_chip">

                                    <ImageView
                                        android:layout_width="17dp"
                                        android:layout_height="17dp"
                                        android:layout_gravity="center"
                                        android:contentDescription="@null"
                                        android:src="@drawable/ic_github" />
                                </FrameLayout>

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="14dp"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:fontFamily="monospace"
                                        android:text="OPEN --GITHUB"
                                        android:textColor="@color/text_faint"
                                        android:textSize="10sp" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="github.com/arjunmehta"
                                        android:textColor="@color/text_hi"
                                        android:textSize="15sp"
                                        android:textStyle="normal" />
                                </LinearLayout>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="→"
                                    android:textColor="@color/text_faint"
                                    android:textSize="16sp" />
                            </LinearLayout>
                        </carbon.widget.LinearLayout>

                        <carbon.widget.LinearLayout
                            android:id="@+id/row_linkedin"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="11dp"
                            android:alpha="0"
                            android:background="@drawable/bg_link_row"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground"
                            android:orientation="horizontal">

                            <View
                                android:layout_width="3dp"
                                android:layout_height="match_parent"
                                android:background="@color/acc_linkedin" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal"
                                android:paddingStart="13dp"
                                android:paddingTop="13dp"
                                android:paddingEnd="16dp"
                                android:paddingBottom="13dp">

                                <FrameLayout
                                    android:layout_width="34dp"
                                    android:layout_height="34dp"
                                    android:background="@drawable/bg_icon_chip">

                                    <ImageView
                                        android:layout_width="17dp"
                                        android:layout_height="17dp"
                                        android:layout_gravity="center"
                                        android:contentDescription="@null"
                                        android:src="@drawable/ic_linkedin" />
                                </FrameLayout>

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="14dp"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:fontFamily="monospace"
                                        android:text="OPEN --LINKEDIN"
                                        android:textColor="@color/text_faint"
                                        android:textSize="10sp" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="linkedin.com/in/arjunmehta"
                                        android:textColor="@color/text_hi"
                                        android:textSize="15sp" />
                                </LinearLayout>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="→"
                                    android:textColor="@color/text_faint"
                                    android:textSize="16sp" />
                            </LinearLayout>
                        </carbon.widget.LinearLayout>

                        <carbon.widget.LinearLayout
                            android:id="@+id/row_instagram"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="11dp"
                            android:alpha="0"
                            android:background="@drawable/bg_link_row"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground"
                            android:orientation="horizontal">

                            <View
                                android:layout_width="3dp"
                                android:layout_height="match_parent"
                                android:background="@color/acc_instagram" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal"
                                android:paddingStart="13dp"
                                android:paddingTop="13dp"
                                android:paddingEnd="16dp"
                                android:paddingBottom="13dp">

                                <FrameLayout
                                    android:layout_width="34dp"
                                    android:layout_height="34dp"
                                    android:background="@drawable/bg_icon_chip">

                                    <ImageView
                                        android:layout_width="17dp"
                                        android:layout_height="17dp"
                                        android:layout_gravity="center"
                                        android:contentDescription="@null"
                                        android:src="@drawable/ic_instagram" />
                                </FrameLayout>

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="14dp"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:fontFamily="monospace"
                                        android:text="OPEN --INSTAGRAM"
                                        android:textColor="@color/text_faint"
                                        android:textSize="10sp" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="@arjun.codes"
                                        android:textColor="@color/text_hi"
                                        android:textSize="15sp" />
                                </LinearLayout>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="→"
                                    android:textColor="@color/text_faint"
                                    android:textSize="16sp" />
                            </LinearLayout>
                        </carbon.widget.LinearLayout>

                        <carbon.widget.LinearLayout
                            android:id="@+id/row_mail"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:alpha="0"
                            android:background="@drawable/bg_link_row"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground"
                            android:orientation="horizontal">

                            <View
                                android:layout_width="3dp"
                                android:layout_height="match_parent"
                                android:background="@color/acc_mail" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal"
                                android:paddingStart="13dp"
                                android:paddingTop="13dp"
                                android:paddingEnd="16dp"
                                android:paddingBottom="13dp">

                                <FrameLayout
                                    android:layout_width="34dp"
                                    android:layout_height="34dp"
                                    android:background="@drawable/bg_icon_chip">

                                    <ImageView
                                        android:layout_width="17dp"
                                        android:layout_height="17dp"
                                        android:layout_gravity="center"
                                        android:contentDescription="@null"
                                        android:src="@drawable/ic_mail" />
                                </FrameLayout>

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="14dp"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:fontFamily="monospace"
                                        android:text="SEND --MAIL"
                                        android:textColor="@color/text_faint"
                                        android:textSize="10sp" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="arjun.mehta.dev@example.com"
                                        android:textColor="@color/text_hi"
                                        android:textSize="15sp" />
                                </LinearLayout>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="→"
                                    android:textColor="@color/text_faint"
                                    android:textSize="16sp" />
                            </LinearLayout>
                        </carbon.widget.LinearLayout>
                    </LinearLayout>

                    <FrameLayout
                        android:id="@+id/cta_wrap"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="22dp"
                        android:alpha="0">

                        <carbon.widget.LinearLayout
                            android:id="@+id/cta_button"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:background="@drawable/bg_cta_pill"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:letterSpacing="0.03"
                                android:text="GET IN TOUCH →"
                                android:textColor="@color/void_bg"
                                android:textSize="14.5sp"
                                android:textStyle="bold" />
                        </carbon.widget.LinearLayout>

                        <View
                            android:id="@+id/cta_shimmer"
                            android:layout_width="60dp"
                            android:layout_height="52dp"
                            android:background="@drawable/bg_shimmer_stripe"
                            android:translationX="-120dp" />
                    </FrameLayout>

                    <LinearLayout
                        android:id="@+id/footer_row"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="16dp"
                        android:alpha="0"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <View
                            android:id="@+id/status_dot"
                            android:layout_width="6dp"
                            android:layout_height="6dp"
                            android:layout_marginEnd="6dp"
                            android:background="@drawable/bg_avatar_circle"
                            android:backgroundTint="@color/neon_green" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="monospace"
                            android:letterSpacing="0.05"
                            android:text="STATUS: AVAILABLE FOR FREELANCE"
                            android:textColor="@color/text_faint"
                            android:textSize="10.5sp" />
                    </LinearLayout>
                </LinearLayout>
            </FrameLayout>
        </FrameLayout>
    </ScrollView>

    <FrameLayout
        android:id="@+id/boot_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/void_bg">

        <LinearLayout
            android:layout_width="300dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/boot_line_1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:alpha="0"
                android:fontFamily="monospace"
                android:text="&gt; initializing devfolio.sys ..."
                android:textColor="@color/neon_green"
                android:textSize="13.5sp" />

            <TextView
                android:id="@+id/boot_line_2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:alpha="0"
                android:fontFamily="monospace"
                android:text="&gt; establishing secure connection ..."
                android:textColor="@color/neon_green"
                android:textSize="13.5sp" />

            <TextView
                android:id="@+id/boot_line_3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:alpha="0"
                android:fontFamily="monospace"
                android:text="&gt; access granted_"
                android:textColor="@color/neon_green"
                android:textSize="13.5sp" />

            <ProgressBar
                android:id="@+id/boot_progress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:max="100"
                android:progress="0"
                android:progressBackgroundTint="@color/panel_border"
                android:progressTint="@color/neon_green" />
        </LinearLayout>
    </FrameLayout>

</FrameLayout>